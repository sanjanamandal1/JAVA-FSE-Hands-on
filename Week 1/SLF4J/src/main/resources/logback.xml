<?xml version="1.0" encoding="UTF-8"?>
<!--
    logback.xml — Logback configuration for Exercise 1
    Placed in src/main/resources so it appears on the classpath.

    Key concepts:
    - Appender : defines WHERE to send log output (console, file, etc.)
    - Encoder  : defines HOW each log line is formatted (pattern)
    - Logger   : controls WHICH log statements from a package are active
    - Root     : catch-all logger; every logger inherits from it

    Log levels (most → least severe):  ERROR > WARN > INFO > DEBUG > TRACE
    A logger set to WARN will output WARN and ERROR, but suppress INFO/DEBUG/TRACE.
-->
<configuration>

    <!-- ================================================================
         APPENDER 1: Console (STDOUT)
         Prints coloured output to the terminal using Logback's built-in
         %highlight() and %boldWhite() conversion words.
         ================================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
                Pattern breakdown:
                  %d{HH:mm:ss.SSS}   — timestamp (hours:minutes:seconds.millis)
                  [%thread]          — thread name
                  %highlight(%-5level) — log level, padded to 5 chars, coloured
                  %boldWhite(%logger{36}) — logger name (class), truncated to 36 chars
                  - %msg%n           — the actual log message, then newline
            -->
            <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %boldWhite(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================
         APPENDER 2: Rolling File
         Writes logs to a file; rolls over daily and when it exceeds 10 MB.
         Keeps at most 7 days of archived log files.
         ================================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- daily rollover; .gz compresses old files automatically -->
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>7</maxHistory>          <!-- keep 7 days of archives  -->
            <totalSizeCap>100MB</totalSizeCap>  <!-- cap total archived size  -->
        </rollingPolicy>
        <encoder>
            <!-- Plain pattern for the file (no ANSI colour codes) -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================
         LOGGER: com.example package
         Set to DEBUG so we see DEBUG + INFO + WARN + ERROR from our code.
         Both appenders are used (console AND file).
         ================================================================ -->
    <logger name="com.example" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- ================================================================
         ROOT logger (catch-all for everything else, e.g. libraries)
         Set to WARN so third-party library noise is suppressed.
         ================================================================ -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
